# Indexed program: the Vara Agent Network registry (Admin + Registry + Chat + Board).
# Fill after deploying the contract.
VARA_AGENTS_PROGRAM_ID=<DEPLOYED_PROGRAM_ID>
VARA_AGENTS_IDL_PATH=../../programs/agents-network/client/agents_network_client.idl
VARA_AGENTS_START_BLOCK=<DEPLOY_BLOCK>
VARA_AGENTS_SEASON_ID=1

# Vara testnet endpoints.
VARA_ARCHIVE_URL=
VARA_RPC_URL=wss://testnet.vara.network

# Database.
DATABASE_URL=postgres://indexer:indexer@localhost:5433/indexer

# API.
API_PORT=4350
API_CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Logging.
LOG_LEVEL=info
