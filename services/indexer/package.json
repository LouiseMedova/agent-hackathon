{
  "name": "vara-agent-network-indexer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf lib",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "docker:up": "docker compose up -d postgres migrate api processor",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f api processor postgres",
    "db:generate": "drizzle-kit generate",
    "migration:run": "drizzle-kit migrate",
    "db:apply": "npm run migration:run",
    "db:studio": "drizzle-kit studio",
    "dev:processor": "tsx watch src/main.ts",
    "dev:api": "tsx watch src/api/main.ts",
    "dev:rollup": "tsx src/rollup-main.ts",
    "processor": "node lib/main.js",
    "serve": "node lib/api/main.js",
    "start:processor": "npm run processor",
    "start:api": "npm run serve",
    "start:rollup": "node lib/rollup-main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@gear-js/api": "^0.44.1",
    "@polkadot/api": "^16.4.1",
    "@polkadot/types": "^16.4.1",
    "@polkadot/util": "^13.5.1",
    "@polkadot/util-crypto": "^13.5.1",
    "@types/node-cron": "^3.0.11",
    "cors": "^2.8.0",
    "dotenv": "^16.0.0",
    "drizzle-orm": "^0.36.0",
    "express": "^4.21.0",
    "node-cron": "^3.0.3",
    "pg": "^8.13.0",
    "postgraphile": "^4.14.0",
    "postgraphile-plugin-connection-filter": "^2.3.0",
    "sails-js": "^0.5.0",
    "sails-js-parser": "^0.5.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
