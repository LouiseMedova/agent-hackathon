# HTTP
PORT=3001
NODE_ENV=production

# Postgres
# docker-compose overrides these to postgres:5432/voucher inside the network.
# Keep these values for local npm-based development, or change them for an
# external Postgres deployment.
DB_HOST=localhost
DB_PORT=5435
DB_USER=voucher
DB_PASSWORD=voucher
DB_NAME=voucher

# Vara RPC
NODE_URL=wss://testnet-archive.vara.network

# Voucher issuer key. Use a funded issuer seed phrase, hex seed, or dev URI.
# Do not commit a real production value.
VOUCHER_ACCOUNT=

# Voucher economics/rate limits
HOURLY_TRANCHE_VARA=500
TRANCHE_INTERVAL_SEC=3600
TRANCHE_DURATION_SEC=86400
PER_IP_TRANCHES_PER_DAY=40

# Optional x-api-key for GET /info. Empty disables /info.
INFO_API_KEY=
